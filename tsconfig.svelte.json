{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "types": ["svelte", "vite/client", "vitest/globals", "node"],
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src-svelte/*"],
      "@generated/*": ["./src/generated/*"]
    }
  },
  "include": [
    "src-svelte/**/*.ts",
    "src-svelte/**/*.svelte",
    "src/generated/**/*.ts",
    "vite.svelte.config.ts",
    "vitest.svelte.config.ts",
    "vitest.svelte.setup.ts"
  ],
  "exclude": [
    "node_modules",
    "web-dist-svelte",
    "src-svelte/**/__tests__/**",
    "src-svelte/**/*.test.ts",
    "src-svelte/**/*.test.svelte.ts",
    "src/generated/**/*.test.ts",
    "src-svelte/services/ml/**",
    "src-svelte/services/validation/**",
    "src-svelte/workers/**",
    "src-svelte/services/dataset/featureRegistry.ts",
    "src-svelte/services/dataset/featureReservoir.ts",
    "src-svelte/services/dataset/export.ts",
    "src-svelte/services/dataset/import.ts",
    "src-svelte/services/posture/detection.ts",
    "src-svelte/services/posture/Keypoint.ts",
    "src-svelte/services/posture/keypointIndices.ts",
    "src-svelte/utils/featureCloning.ts"
  ]
}

{
  "name": "slouch_tracker",
  "type": "module",
  "version": "1.1.0",
  "description": "Real-time webcam posture detection desktop app (Tauri 2 + Svelte 5 + native Rust ML/vision)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SSS135/slouch_tracker.git"
  },
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "vite --config vite.svelte.config.ts",
    "dev:svelte": "vite --config vite.svelte.config.ts",
    "build": "vite build --config vite.svelte.config.ts",
    "build:web": "vite build --config vite.svelte.config.ts",
    "build:svelte": "vite build --config vite.svelte.config.ts",
    "build:svelte:harness": "vite build --config vite.svelte-harness.config.ts",
    "check:svelte": "svelte-check --tsconfig ./tsconfig.svelte.json",
    "check:svelte:plumbing": "tsc --noEmit --project ./tsconfig.svelte.plumbing.json",
    "svelte-check": "npm run check:svelte",
    "typecheck": "svelte-check --tsconfig ./tsconfig.svelte.json",
    "lint": "eslint src-svelte src/generated e2e scripts",
    "lint:svelte": "eslint src-svelte src/generated/bindings.ts src/generated/bindings.contract.test.ts",
    "scan:svelte:runtime": "node scripts/check-svelte-runtime.mjs",
    "test:svelte": "vitest run --config vitest.svelte.config.ts",
    "preview": "vite preview --config vite.svelte.config.ts",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build --ignore-version-mismatches",
    "tauri:build:win": "tauri build --target x86_64-pc-windows-msvc --ignore-version-mismatches",
    "tauri:build:dev": "tauri build --config src-tauri/tauri.conf.dev.json --features devbuild --ignore-version-mismatches --no-bundle",
    "tauri:build:dev:win": "tauri build --config src-tauri/tauri.conf.dev.json --features devbuild --target x86_64-pc-windows-msvc --ignore-version-mismatches --no-bundle",
    "validate:port-manifest": "node scripts/validate-port-manifest.mjs",
    "acceptance:check": "node scripts/validate-acceptance.mjs --final",
    "bindings:generate": "cargo run --locked --manifest-path src-tauri/Cargo.toml --bin export_bindings",
    "bindings:check": "node scripts/check-bindings.mjs",
    "test:e2e:web": "playwright test --config playwright.config.ts",
    "test:e2e:native": "wdio run wdio.conf.ts",
    "test:security": "node scripts/run-security-gates.mjs",
    "package:inspect": "node scripts/inspect-package.mjs",
    "verify:migration": "node scripts/verify-migration.mjs",
    "test": "vitest run --config vitest.svelte.config.ts",
    "test:spo": "vitest run --config vitest.svelte.config.ts --silent=passed-only",
    "test:fast": "vitest run --config vitest.svelte.config.ts",
    "test:watch": "vitest --watch --config vitest.svelte.config.ts",
    "test:ui": "vitest --ui --config vitest.svelte.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.svelte.config.ts"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.2",
    "@tanstack/svelte-query": "6.1.36",
    "@tauri-apps/api": "2.9.0",
    "@tauri-apps/plugin-global-shortcut": "2.3.1",
    "svelte": "5.56.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@sveltejs/vite-plugin-svelte": "5.1.1",
    "@tauri-apps/cli": "2.9.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "5.4.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mocha": "10.0.10",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "@vitest/coverage-v8": "^4.0.8",
    "@vitest/ui": "^4.0.8",
    "@wdio/cli": "9.27.1",
    "@wdio/globals": "9.27.1",
    "@wdio/local-runner": "9.27.1",
    "@wdio/mocha-framework": "9.27.1",
    "@wdio/spec-reporter": "9.27.1",
    "@wdio/tauri-service": "1.2.0",
    "eslint": "^9.25.0",
    "eslint-plugin-svelte": "3.20.0",
    "fake-indexeddb": "^6.2.3",
    "jsdom": "^27.1.0",
    "svelte-check": "4.6.0",
    "svelte-eslint-parser": "1.8.0",
    "tsx": "^4.19.0",
    "typescript": "~5.8.3",
    "vite": "6.4.1",
    "vitest": "^4.0.8"
  },
  "overrides": {
    "@wdio/native-utils": "2.5.0"
  },
  "private": true
}

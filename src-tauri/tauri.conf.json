{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Slouch Tracker",
  "version": "1.0.0",
  "identifier": "com.slouchtracker.main",
  "build": {
    "frontendDist": "../web-dist-svelte",
    "devUrl": "http://127.0.0.1:5174",
    "beforeDevCommand": "npm run dev:svelte",
    "beforeBuildCommand": "npm run build:svelte"
  },
  "app": {
    "windows": [
      {
        "title": "Slouch Tracker",
        "url": "index.svelte.html",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "center": true,
        "devtools": false,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; style-src-attr 'unsafe-inline'; img-src 'self' blob: slouchcam: http://slouchcam.localhost; media-src 'self'; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost slouchcam: http://slouchcam.localhost; worker-src 'none'; object-src 'none'; frame-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; manifest-src 'none'",
      "devCsp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; style-src-attr 'unsafe-inline'; img-src 'self' data: blob: slouchcam: http://slouchcam.localhost; media-src 'self'; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost slouchcam: http://slouchcam.localhost ws://127.0.0.1:5174 ws://localhost:5174 http://127.0.0.1:5174; worker-src 'self' blob:; object-src 'none'; frame-src 'none'; base-uri 'self'; form-action 'self'; manifest-src 'none'"
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "copyright": "Copyright (c) Slouch Tracker Contributors",
    "licenseFile": "../LICENSE",
    "resources": {
      "resources/models/rtmdet-nano.onnx": "resources/models/rtmdet-nano.onnx",
      "resources/models/nlf_l_crop_fp16.onnx": "resources/models/nlf_l_crop_fp16.onnx",
      "resources/onnxruntime/windows-x86_64/onnxruntime.dll": "resources/onnxruntime/windows-x86_64/onnxruntime.dll",
      "resources/onnxruntime/windows-x86_64/DirectML.dll": "resources/onnxruntime/windows-x86_64/DirectML.dll",
      "resources/onnxruntime/windows-x86_64/onnxruntime_providers_shared.dll": "resources/onnxruntime/windows-x86_64/onnxruntime_providers_shared.dll",
      "resources/onnxruntime/notices/LICENSE": "resources/onnxruntime/notices/LICENSE",
      "resources/onnxruntime/notices/Privacy.md": "resources/onnxruntime/notices/Privacy.md",
      "resources/onnxruntime/notices/ThirdPartyNotices.txt": "resources/onnxruntime/notices/ThirdPartyNotices.txt"
    },
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
